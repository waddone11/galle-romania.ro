includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
        - database/

    level: 5

    checkOctaneCompatibility: false
    checkModelProperties: true

    # Vendor config files (config/) reference paid-tier classes (e.g. MediaLibrary Pro) that
    # we don't install — analysing config/ adds noise without business value.
